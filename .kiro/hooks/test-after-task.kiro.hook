{
  "enabled": true,
  "name": "Run Tests After Task",
  "description": "Runs pytest in fast-fail mode after each spec task is marked complete",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": ".venv/bin/python -m pytest tests/ -x -q"
  }
}
